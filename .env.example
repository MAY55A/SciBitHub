# ─── Supabase ───────────────────────────────────────────────
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY= # from `npx supabase start` output
NEXT_SUPABASE_SERVICE_ROLE_KEY= # from `npx supabase start` output

# ─── MinIO ──────────────────────────────────────────────────
# Default values work out of the box with the Docker setup described in CONTRIBUTING.md
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=sci-bit-hub

# ─── GitHub Release ─────────────────────────────────────────
# GitHub repository and release tag used to fetch seed data assets.
GITHUB_OWNER=MAY55A
GITHUB_REPO=scibithub
GITHUB_RELEASE_TAG=seed-data-v1.0.0