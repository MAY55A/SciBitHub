# ─── Supabase ───────────────────────────────────────────────
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY= # from `npx supabase start` output
NEXT_SUPABASE_SERVICE_ROLE_KEY= # from `npx supabase start` output

# ─── MinIO (local dev) ──────────────────────────────────────
# Default values work out of the box with the Docker setup described in CONTRIBUTING.md
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=sci-bit-hub